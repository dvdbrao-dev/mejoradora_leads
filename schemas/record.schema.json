{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Openfang Record",
  "type": "object",
  "required": ["record_version", "lead", "pipeline"],
  "properties": {
    "record_version": {
      "type": "string"
    },
    "lead": {
      "type": "object",
      "required": ["lead_id", "created_at", "source", "entity"],
      "properties": {
        "lead_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "entity": {
          "type": "object",
          "required": ["name", "category", "contacts"],
          "properties": {
            "name": {
              "type": "string"
            },
            "category": {
              "type": "string"
            },
            "contacts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "value"],
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "signals": {
          "type": "array"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "pipeline": {
      "type": "object",
      "required": ["stage", "updated_at", "run_id"],
      "properties": {
        "stage": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        }
      }
    }
  }
}
